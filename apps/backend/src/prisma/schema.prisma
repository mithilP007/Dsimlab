datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// better-auth Models
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean
  name          String
  image         String?
  role          String    @default("STUDENT_COLLEGE") // STUDENT_COLLEGE, INDIVIDUAL, INSTRUCTOR, ADMIN
  institution   String?
  planType      String?
  classId       String?
  class         Class?    @relation("ClassStudents", fields: [classId], references: [id], onDelete: SetNull)
  
  // Custom instructor details fields
  phoneNumber    String?
  universityRole String?
  age            Int?
  gender         String?
  category       String?
  status         String    @default("active") // active, suspended, pending

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([classId])
  @@index([role])

  sessions      Session[]
  accounts      Account[]
  
  // Instructor relations
  managedClasses Class[]  @relation("ClassInstructor")
  
  // Student relations
  simulations   SimulationState[]
  campaignRuns  CampaignRun[]
  auditLogs     AuditLog[]
  notifications Notification[]
  scenarioAssignments        ScenarioAssignment[]        @relation("ScenarioAssignmentInstructor")
  scenarioAssignmentStudents ScenarioAssignmentStudent[] @relation("StudentAssignments")

  // Billing relations
  subscriptions Subscription[]
  invoices      Invoice[]
  couponUsages  CouponUsage[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Simulation Models
model Class {
  id           String            @id @default(uuid())
  name         String
  inviteCode   String            @unique
  instructorId String
  instructor   User              @relation("ClassInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  scenarioId   String
  scenario     Scenario          @relation(fields: [scenarioId], references: [id])
  students     User[]            @relation("ClassStudents")
  simulations  SimulationState[]
  campaignRuns CampaignRun[]
  scenarioAssignments ScenarioAssignment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([instructorId])
  @@index([scenarioId])
}

model Scenario {
  id                            String   @id @default(uuid())
  name                          String
  description                   String
  industry                      String
  startRound                    Int      @default(1)
  maxRounds                     Int      @default(10)
  budgetPerRound                Float    @default(5000.0)
  baselineOrganicTraffic        Int      @default(1000)
  targetKPI                     String   @default("revenue") // revenue, clicks, conversions
  location                      String   @default("Global")
  durationDays                  Int      @default(30)
  dailyBudgetCap                Float    @default(50.0)
  platforms                     String   @default("[\"SEO\", \"GOOGLE_ADS\", \"META_ADS\"]")
  dataMode                      String   @default("REAL_TIME_TREND_SIMULATION")
  refreshTrendEveryRound        Boolean  @default(true)
  
  // New lab config fields
  scenarioType                  String   @default("standard")
  totalBudget                   Float    @default(5000.0)
  allowedPlatforms              String   @default("[\"SEO\", \"GOOGLE_ADS\", \"META_ADS\"]")
  allowedGoogleObjectives       String   @default("[\"Sales\", \"Leads\", \"Website Traffic\", \"Brand Awareness\"]")
  allowedMetaObjectives         String   @default("[\"Awareness\", \"Traffic\", \"Engagement\", \"Leads\", \"Sales\"]")
  allowedBiddingStrategies      String   @default("[\"Manual CPC\", \"Maximize Clicks\", \"Maximize Conversions\"]")
  allowedAudienceKeywordOptions String   @default("[]")
  targetLocations               String   @default("[\"Global\"]")
  difficulty                    String   @default("medium")
  marketVolatility              Float    @default(1.0)
  trendRefreshFrequency         String   @default("daily")
  scoringWeights                String   @default("{\"alignment\":0.2,\"budget\":0.1,\"optimization\":0.2,\"keywordAudience\":0.2,\"creative\":0.15,\"roi\":0.15}")
  aiHintsEnabled                Boolean  @default(true)
  certificateEnabled            Boolean  @default(true)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  classes                       Class[]
  campaignRuns                  CampaignRun[]
  scenarioAssignments           ScenarioAssignment[]
}

model SimulationState {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId          String
  class            Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  currentRound     Int              @default(1)
  status           String           @default("INITIALIZED") // INITIALIZED, DECISION_OPEN, LOCKED, PROCESSING, RESULTS_READY, SCORE_LOCKED, COMPLETED
  isCompleted      Boolean          @default(false)
  cumulativeSpend  Float            @default(0.0)
  cumulativeRevenue Float           @default(0.0)
  score            Float            @default(0.0)
  instructorApproved Boolean        @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  decisions        Decision[]
  metrics          DailyMetric[]
  scoreBreakdowns  ScoreBreakdown[]
  certificates     Certificate[]
  snapshots        RoundSnapshot[]
  progress         StudentSimulationProgress?
  checkpointValidations CheckpointValidation[]
  hardViolations        HardViolation[]

  @@index([userId, status])
  @@index([classId, isCompleted])
}

model Decision {
  id                 String          @id @default(uuid())
  simulationId       String
  simulation         SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  round              Int
  createdAt          DateTime        @default(now())
  
  // SEO Decisions (JSON fields for target keywords/strategy)
  seoTargetKeywords  String          // JSON array of strings
  seoContentQuality  Float           @default(5.0) // 1-10 content quality score
  seoBacklinkBudget  Float           @default(0.0)
  
  // Extended SEO Decisions
  seoMetaTitle       String?
  seoMetaDescription String?
  seoBodyContent     String?
  seoUrlSlug         String?
  seoInternalLinks   Int?            @default(0)
  seoAnchorText      String?
  seoBacklinkQuality Int?            @default(1)
  seoTechnicalConfig String?         // JSON object representing SSL, Sitemap, Robots, etc.
  seoCoreWebVitals   String?         // JSON object representing LCP, CLS, FID
  
  // Google Ads Campaigns (JSON list of campaign configurations)
  googleCampaigns    String          // JSON array: { name, budget, keywords: { word: string, bid: number }[] }
  
  // Meta Ads Campaigns (JSON list of campaigns)
  metaCampaigns      String          // JSON array: { name, budget, audienceInterest: string, bidType: string, bidAmount: number, placement: string, creativeQuality: number }
  
  submitted          Boolean         @default(false)

  @@unique([simulationId, round])
}

model DailyMetric {
  id                 String          @id @default(uuid())
  simulationId       String
  simulation         SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  round              Int
  day                Int             // Day 1 to 30 of simulation round
  createdAt          DateTime        @default(now())

  // Organic (SEO) metrics
  organicImpressions Int             @default(0)
  organicClicks      Int             @default(0)
  organicCTR         Float           @default(0.0)
  organicConversions Int             @default(0)

  // Paid Google Ads metrics
  googleImpressions  Int             @default(0)
  googleClicks       Int             @default(0)
  googleCost         Float           @default(0.0)
  googleConversions  Int             @default(0)

  // Paid Meta Ads metrics
  metaImpressions    Int             @default(0)
  metaClicks         Int             @default(0)
  metaCost           Float           @default(0.0)
  metaConversions    Int             @default(0)

  // Financials
  revenue            Float           @default(0.0)

  @@index([simulationId, round])
}

model MarketEvent {
  id                 String          @id @default(uuid())
  simulationId       String
  round              Int
  name               String
  description        String
  type               String          // ALGORITHM_UPDATE, SEASONAL_SPIKE, COMPETITOR_PRICE_DROP
  impactMultiplier   Float           @default(1.0)
  createdAt          DateTime        @default(now())
}

model ScoreBreakdown {
  id                 String          @id @default(uuid())
  simulationId       String
  simulation         SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  round              Int
  seoScore           Float           @default(0.0)
  googleAdsScore     Float           @default(0.0)
  metaAdsScore       Float           @default(0.0)
  budgetScore        Float           @default(0.0)
  revenueScore       Float           @default(0.0)

  // Phase 3 Aligned Scoring Fields
  strategicAlignment Float           @default(0.0)
  efficiencyRoi      Float           @default(0.0)
  budgetDiscipline   Float           @default(0.0)
  riskManagement     Float           @default(0.0)
  adaptability       Float           @default(0.0)
  strategicConsistency Float         @default(0.0)

  compositeIndex     Float           @default(0.0)
  percentileRank     Float           @default(0.0)
  createdAt          DateTime        @default(now())

  @@unique([simulationId, round])
  @@index([simulationId, round])
}

model Certificate {
  id                 String          @id @default(uuid())
  simulationId       String
  simulation         SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  userId             String
  recipientName      String
  issueDate          DateTime        @default(now())
  verificationHash   String          @unique
  verificationId     String?         @unique
  compositeScore     Float
  pdfUrl             String
  band               String          @default("COMPETENT")
  skills             String          @default("[]")
  createdAt          DateTime        @default(now())

  @@index([userId])
  @@index([simulationId])
}

model AuditLog {
  id                 String          @id @default(uuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  action             String
  details            String
  ipAddress          String?
  createdAt          DateTime        @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RoundSnapshot {
  id           String          @id @default(uuid())
  simulationId String
  simulation   SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  round        Int
  data         String          // Serialized JSON of RoundSnapshot
  createdAt    DateTime        @default(now())

  @@unique([simulationId, round])
  @@index([simulationId, round])
}

model TrendSnapshot {
  id              String                @id @default(uuid())
  simulationId    String?
  roundNumber     Int?
  scenarioId      String
  campaignRunId   String?
  campaignRun     CampaignRun?          @relation(fields: [campaignRunId], references: [id], onDelete: Cascade)
  dayNumber       Int?
  industry        String
  location        String
  platform        String?
  signals         Json?                 // Stored TrendSignal array or object (compatibility)
  sources         Json?                 // compatibility
  confidence      Float?                // compatibility
  source          String?               // GOOGLE_TRENDS, FALLBACK, etc.
  confidenceScore Float?                @default(1.0)
  trendDataJson   Json?
  rawPayloadJson  Json?
  fetchedAt       DateTime              @default(now())
  createdAt       DateTime              @default(now())

  results         DailyCampaignResult[]

  @@index([simulationId, roundNumber])
  @@index([campaignRunId, dayNumber])
}

model MarketConditionSnapshot {
  id                 String          @id @default(uuid())
  simulationId       String
  roundNumber        Int
  demandIndex        Float
  competitionIndex   Float
  cpcPressure        Float
  cpmPressure        Float
  conversionIntent   Float
  seasonalImpact     Float
  newsImpact         Float
  socialBuzzImpact   Float           @default(1.0)
  platformModifiers  Json
  createdAt          DateTime        @default(now())

  @@index([simulationId, roundNumber])
}

model StudentSimulationProgress {
  id              String          @id @default(uuid())
  simulationId    String          @unique
  simulation      SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  currentDay      Int             @default(1)
  totalDays       Int             @default(30)
  status          String          @default("DECISION_OPEN")
  lastSubmittedAt DateTime?
  nextResultAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // info, success, warning, achievement
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  actor     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, read])
}

model Plan {
  id                String         @id @default(uuid())
  name              String         @unique // Free Trial, Individual Basic, Individual Pro, Instructor, College, Enterprise
  code              String         @unique // free, individual_basic, individual_pro, instructor, college, enterprise
  priceMonthly      Float
  priceYearly       Float
  currency          String         @default("INR")
  simulationLimit   Int            // -1 for unlimited
  studentLimit      Int            // Max students per class
  instructorLimit   Int            // Max instructors under a college
  certificateLimit  Int
  reportExportLimit Int
  storageLimitMb    Int            @default(50)
  features          String         // JSON array of strings
  isActive          Boolean        @default(true)
  durationDays      Int            @default(30)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  subscriptions     Subscription[]
}

model Subscription {
  id                   String         @id @default(uuid())
  userId               String
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan           @relation(fields: [planId], references: [id])
  status               String         // active, trialing, past_due, cancelled, expired
  billingCycle         String         // monthly, yearly, trial
  startDate            DateTime       @default(now())
  endDate              DateTime
  cancelAtPeriodEnd    Boolean        @default(false)
  gatewaySubscriptionId String?        @unique
  gatewayCustomerId    String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  invoices             Invoice[]
  payments             Payment[]
  couponUsages         CouponUsage[]

  @@index([userId, status])
  @@index([planId])
}

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceNumber  String        @unique // INV-YYYY-XXXX
  amount         Float
  tax            Float         @default(0.0)
  currency       String        @default("INR")
  status         String        // paid, unpaid, void, refunded
  pdfUrl         String?
  billingAddress String?
  taxDetails     String?       // GSTIN or Tax identification
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payments       Payment[]

  @@index([userId])
  @@index([subscriptionId])
}

model Payment {
  id               String        @id @default(uuid())
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoiceId        String?
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amount           Float
  currency         String        @default("INR")
  status           String        // captured, failed, pending, refunded
  gateway          String        @default("razorpay")
  gatewayPaymentId String        @unique
  gatewayOrderId   String?
  gatewaySignature String?
  refundedAmount   Float         @default(0.0)
  errorMessage     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([subscriptionId])
  @@index([invoiceId])
}

model Coupon {
  id              String        @id @default(uuid())
  code            String        @unique
  discountType    String        // percentage, flat, trial_extension
  discountValue   Float
  durationMonths  Int?          // Null means lifetime/forever
  expirationDate  DateTime?
  maxRedemptions  Int?
  redemptionsCount Int          @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  usages          CouponUsage[]
}

model CouponUsage {
  id             String       @id @default(uuid())
  couponId       String
  coupon         Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  usedAt         DateTime     @default(now())

  @@index([userId])
  @@index([couponId])
  @@index([subscriptionId])
}

model BillingEvent {
  id         String   @id @default(uuid())
  eventType  String
  payload    String   // JSON string
  processed  Boolean  @default(false)
  error      String?
  createdAt  DateTime @default(now())
}

// Daily Campaign Simulation Models
model CampaignRun {
  id                String                        @id @default(uuid())
  userId            String
  user              User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId        String
  scenario          Scenario                      @relation(fields: [scenarioId], references: [id])
  classId           String?
  class             Class?                        @relation(fields: [classId], references: [id], onDelete: SetNull)
  assignmentId      String?
  assignment        ScenarioAssignment?           @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  assignmentStudents ScenarioAssignmentStudent[]
  durationDays      Int                           @default(30)
  currentDay        Int                           @default(1)
  status            String                        @default("INITIALIZED") // INITIALIZED, ACTIVE, COMPLETED
  startedAt         DateTime                      @default(now())
  endsAt            DateTime
  lastProcessedAt   DateTime?
  nextProcessingAt  DateTime

  decisions         DailyCampaignDecision[]
  results           DailyCampaignResult[]
  recommendations   DailyCampaignRecommendation[]
  snapshots         TrendSnapshot[]
  processingJobs    CampaignProcessingJob[]

  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@index([userId])
  @@index([classId])
  @@index([status])
  @@index([nextProcessingAt])
}

model DailyCampaignDecision {
  id                     String      @id @default(uuid())
  campaignRunId          String
  campaignRun            CampaignRun @relation(fields: [campaignRunId], references: [id], onDelete: Cascade)
  userId                 String
  dayNumber              Int
  seoSettingsJson        Json        // targetKeywords, contentQuality, backlinkBudget, metaTitle, metaDescription, h1Header, bodyContent
  googleAdsSettingsJson  Json        // campaigns: { name, budget, biddingStrategy, keywords: { word, bid }[] }
  metaAdsSettingsJson    Json        // campaigns: { name, budget, audienceInterest, placement, bidType, bidAmount, creativeQuality, creative: { headline, primaryText } }
  budgetJson             Json        // total allocated budget
  submittedAt            DateTime    @default(now())
  lockedAt               DateTime?

  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@unique([campaignRunId, dayNumber])
  @@index([userId])
}

model DailyCampaignResult {
  id                String         @id @default(uuid())
  campaignRunId     String
  campaignRun       CampaignRun    @relation(fields: [campaignRunId], references: [id], onDelete: Cascade)
  userId            String
  dayNumber         Int
  trendSnapshotId   String?
  trendSnapshot     TrendSnapshot? @relation(fields: [trendSnapshotId], references: [id], onDelete: SetNull)

  // Paid/Organic details
  impressions       Int            @default(0)
  clicks            Int            @default(0)
  ctr               Float          @default(0.0)
  cpc               Float          @default(0.0)
  cpa               Float          @default(0.0)
  conversions       Int            @default(0)
  revenue           Float          @default(0.0)
  spend             Float          @default(0.0)
  roas              Float          @default(0.0)

  // Platform breakdowns
  seoTraffic        Int            @default(0)
  seoRank           Int            @default(0)
  authorityScore    Float          @default(0.0)
  metaReach         Int            @default(0)
  metaEngagement    Int            @default(0)

  // Scores
  googleAdsScore    Float          @default(0.0)
  metaAdsScore      Float          @default(0.0)
  seoScore          Float          @default(0.0)
  compositeScore    Float          @default(0.0)

  generatedAt       DateTime       @default(now())

  @@unique([campaignRunId, dayNumber])
  @@index([userId])
}

model DailyCampaignRecommendation {
  id                 String      @id @default(uuid())
  campaignRunId      String
  campaignRun        CampaignRun @relation(fields: [campaignRunId], references: [id], onDelete: Cascade)
  dayNumber          Int
  recommendationType String      // SEO | GOOGLE_ADS | META_ADS | BUDGET
  message            String
  priority           String      // HIGH | MEDIUM | LOW
  expectedImpact     String
  createdAt          DateTime    @default(now())

  @@index([campaignRunId, dayNumber])
}

model CampaignProcessingJob {
  id             String      @id @default(uuid())
  campaignRunId  String
  campaignRun    CampaignRun @relation(fields: [campaignRunId], references: [id], onDelete: Cascade)
  dayNumber      Int
  jobStatus      String      // PENDING | PROCESSING | COMPLETED | FAILED
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?
  retryCount     Int         @default(0)
  idempotencyKey String      @unique

  @@unique([campaignRunId, dayNumber])
}

model ScenarioAssignment {
  id                  String                      @id @default(uuid())
  instructorId        String
  instructor          User                        @relation("ScenarioAssignmentInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  institutionId       String?
  classId             String
  class               Class                       @relation(fields: [classId], references: [id], onDelete: Cascade)
  scenarioId          String
  scenario            Scenario                    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  targetType          String                      // CLASS, GROUP, STUDENT
  targetStudentIdsJson String                     // Storing student IDs as JSON string e.g. '["id1","id2"]'
  assignmentName      String
  durationDays        Int                         @default(30) // 15 or 30
  startDate           DateTime
  endDate             DateTime
  dailyProcessingTime String                      // e.g., "09:00"
  dailyBudgetCap      Float
  difficulty          String
  autoStart           Boolean                     @default(false)
  status              String                      @default("DRAFT") // DRAFT, SCHEDULED, ACTIVE, COMPLETED, CANCELLED
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  students            ScenarioAssignmentStudent[]
  campaignRuns        CampaignRun[]

  @@index([instructorId])
  @@index([classId])
  @@index([scenarioId])
  @@index([status])
}

model ScenarioAssignmentStudent {
  id            String             @id @default(uuid())
  assignmentId  String
  assignment    ScenarioAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId     String
  student       User               @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  campaignRunId String?
  campaignRun   CampaignRun?       @relation(fields: [campaignRunId], references: [id], onDelete: SetNull)
  status        String             @default("ASSIGNED") // ASSIGNED, STARTED, COMPLETED, CANCELLED
  assignedAt    DateTime           @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Institution {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // Registration/Invite code for this college
  status    String   @default("active") // active, suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CheckpointValidation {
  id                     String          @id @default(uuid())
  simulationId           String
  simulation             SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  roundNumber            Int
  studentId              String
  justificationText      String
  reflectionQualityScore Float           @default(0.0)
  submittedAt            DateTime        @default(now())
  status                 String          @default("SUBMITTED") // SUBMITTED, APPROVED, REJECTED
  instructorComment      String?

  @@index([simulationId])
  @@index([studentId])
}

model HardViolation {
  id           String          @id @default(uuid())
  simulationId String
  simulation   SimulationState @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  roundNumber  Int
  studentId    String?
  type         String          // e.g. BUDGET_EXCEEDED, POLICY_VIOLATION, CHECKPOINT_MISSING
  severity     String          @default("BLOCKING") // WARNING, CRITICAL, BLOCKING
  message      String
  source       String?         // e.g. GOOGLE_ADS, META_ADS, SEO, SYSTEM
  createdAt    DateTime        @default(now())

  @@index([simulationId])
  @@index([studentId])
}

model ClassEnrollment {
  id                    String    @id @default(uuid())
  classId               String
  studentId             String
  studentEmail          String
  status                String    @default("PENDING") // PENDING, ACTIVE, REJECTED, REMOVED, TERMINATED
  requestedAt           DateTime  @default(now())
  approvedAt            DateTime?
  rejectedAt            DateTime?
  removedAt             DateTime?
  actionByInstructorId  String?
  rejectionReason       String?
  removalReason         String?

  @@index([classId])
  @@index([studentId])
  @@index([studentEmail])
}

