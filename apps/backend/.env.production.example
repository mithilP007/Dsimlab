###############################################################################
# Digital Marketing Simulation Lab - Production Environment Variables Template
# 
# WARNING: NEVER COMMIT THE REAL .env FILE OR PRODUCTION SECRETS TO GIT.
# Copy this file to .env.production on the server and update the values.
###############################################################################

# General Application Configuration
NODE_ENV=production
PORT=5000

# CORS Configuration
# Must match the production frontend application domain (e.g. Vercel, Netlify)
FRONTEND_URL=https://your-frontend-app.vercel.app
# Comma-separated list of extra trusted origins (required in production; no wildcards)
CORS_ORIGINS=https://your-frontend-app.vercel.app,https://your-preview-app.vercel.app

# Database Configuration (PostgreSQL Production Instance)
# Ensure to use a production connection pool URL if deploying on Serverless hosts
DATABASE_URL="postgresql://db_user:db_password@db_host:5432/db_name?sslmode=require&schema=public"

# Redis Cache and Event Queue Configuration (BullMQ + Socket.io adapter)
# Must point to the production Redis instance
REDIS_URL="redis://:redis_password@redis_host:6379"

# Better Auth Secret (Use a strong generated key, minimum 32 characters long)
BETTER_AUTH_SECRET="use_a_secure_generated_32_character_random_string"

# Better Auth API URL (Must be the base URL of your deployed backend)
BETTER_AUTH_URL=https://your-backend-app.railway.app

# Ollama LLM Configuration (For production AI insights)
# If using a self-hosted Ollama on the same server, point to localhost or docker network.
# If Ollama is local and backend is on Railway/Render, insights will fallback to mock
# analytics model. You can point this to a hosted Ollama server or leave it as is.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
