{
  "name": "marketing-simulation-backend",
  "version": "1.0.0",
  "description": "Digital Marketing Simulation Backend",
  "main": "dist/index.js",
  "type": "commonjs",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --fileParallelism=false",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:status": "prisma migrate status",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node src/seed/master-seed.ts"
  },
  "dependencies": {
    "@better-auth/core": "^1.6.14",
    "@better-auth/prisma-adapter": "^1.6.14",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@prisma/client": "^5.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "better-auth": "^1.6.14",
    "bullmq": "^5.8.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.11.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.1.0",
    "seedrandom": "^3.0.5",
    "socket.io": "^4.7.5",
    "socket.io-redis": "^5.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pdfkit": "^0.17.6",
    "@types/seedrandom": "^3.0.8",
    "@types/socket.io-redis": "^1.0.27",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
