# Server configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Database configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dmsimlab?schema=public"

# Better Auth Secret (should be 32+ characters) and URL
BETTER_AUTH_SECRET="your_better_auth_secret_key_32_characters_long"
BETTER_AUTH_URL="http://localhost:5000"

# BullMQ Redis configuration (empty if using local fallback/mock queue)
REDIS_URL="redis://127.0.0.1:6379"

# Ollama local LLM configuration
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b"
