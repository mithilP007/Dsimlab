# ─────────────────────────────────────────────
# SimLab Backend — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
# CORS_ORIGINS="http://localhost:5173" # Comma-separated list of extra trusted origins (required in production)

# Database (PostgreSQL via docker-compose.dev.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dmsimlab?schema=public"

# Auth (must be 32+ chars; change in production)
BETTER_AUTH_SECRET="change_this_to_a_random_32_character_string!!"
BETTER_AUTH_URL="http://localhost:5000"

# Redis — OPTIONAL in development.
# If omitted, the app uses in-memory fallback for queues and WebSocket adapter.
# To enable Redis: start it with docker-compose.dev.yml and uncomment below.
# REDIS_URL="redis://127.0.0.1:6379"

# Ollama local LLM — OPTIONAL.
# If not running, the app falls back to a deterministic rules-based scorer.
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b"

# Simulation behaviour
ROUND_PROCESSING_MODE=immediate
ROUND_DELAY_HOURS=24
TREND_REFRESH_MODE=per_round
LIVE_AD_ACCOUNT_MODE=false

# ─── Optional: Live ad platform credentials ───────────────────────────────────
# Leave blank unless you are testing against real Google/Meta accounts.

# Google Ads API
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_REFRESH_TOKEN=""
GOOGLE_ADS_CUSTOMER_ID=""

# Meta Marketing API
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
